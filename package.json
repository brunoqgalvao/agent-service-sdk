{
  "name": "agent-service-sdk",
  "version": "0.1.0",
  "description": "Expose one service to many AI agent surfaces from a single definition.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agent-service-sdk": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brunoqgalvao/agent-service-sdk.git"
  },
  "homepage": "https://github.com/brunoqgalvao/agent-service-sdk#readme",
  "bugs": {
    "url": "https://github.com/brunoqgalvao/agent-service-sdk/issues"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "commander": "^14.0.1",
    "fastify": "^5.6.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
